# Server Configuration
PORT=3001
NODE_ENV=development

# AWS Configuration
# PRODUCTION: Use EC2 IAM role — no access keys needed.
# LOCAL DEV: Use `aws configure sso` or `aws configure` with your profile.
# DO NOT add AWS_ACCESS_KEY_ID or AWS_SECRET_ACCESS_KEY here.
AWS_REGION=us-east-1

# AWS Bedrock
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# SuperNova domain (production only — used for CORS)
# APP_DOMAIN=https://abm.amazon.dev

# ElevenLabs Configuration (optional — only if using voice features)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_MODEL_ID=eleven_monolingual_v1

# Client Configuration (local dev only — production uses same-origin)
VITE_API_URL=http://localhost:3002
